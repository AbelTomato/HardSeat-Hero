# 后端数据源
# 默认值：mock
TRAIN_DATA_PROVIDER=mock

# 当 TRAIN_DATA_PROVIDER=static-price 时必填；建议使用相对路径
STATIC_PRICE_DB=./data/static_prices.sqlite3

# 可选：static-only | local-only | static-with-remote-fallback | remote-fallback | fallback
STATIC_PRICE_MODE=static-only

# 可选：当 STATIC_PRICE_MODE 使用远程回填时生效；默认 12306-public-price
STATIC_PRICE_FALLBACK_PROVIDER=12306-public-price

# 可选：静态票价最大可接受年龄（天）；空值表示不限制
STATIC_PRICE_MAX_AGE_DAYS=30

# 路线搜索引擎
# 默认值：candidate
ROUTE_SEARCH_ENGINE=candidate

# 当 ROUTE_SEARCH_ENGINE=time-expanded 时必填；优先级高于 STATIC_PRICE_DB
TIME_EXPANDED_GRAPH_DB=./data/static_prices.sqlite3

# 可选：time-expanded 模式下使用的数据源标识；默认 12306-public-price
TIME_EXPANDED_GRAPH_PROVIDER=12306-public-price

# 可选缓存/遥测
ROUTE_SEGMENT_CACHE_DB=./data/route_segment_cache.sqlite3
ROUTE_SEGMENT_CACHE_TTL_SECONDS=3600
SEARCH_TELEMETRY_DB=./data/search_telemetry.sqlite3

# 前端
# 默认值：http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000